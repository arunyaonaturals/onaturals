{
    "version": 2,
    "public": true,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "^/$",
            "dest": "/public/index.html"
        },
        {
            "src": "/login.html",
            "dest": "/public/login.html"
        },
        {
            "src": "/index.html",
            "dest": "/public/index.html"
        },
        {
            "src": "/styles.css",
            "dest": "/public/styles.css"
        },
        {
            "src": "/app.js",
            "dest": "/public/app.js"
        },
        {
            "src": "/favicon.png",
            "dest": "/public/favicon.png"
        },
        {
            "src": "/js/(.*)",
            "dest": "/public/js/$1"
        }
    ]
}